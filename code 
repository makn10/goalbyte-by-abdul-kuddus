    <script>
        const knobFB = document.getElementById('knob-f-b'), bgFB = document.getElementById('slider-v-bg'), fillV = document.getElementById('fill-v');
        const knobLR = document.getElementById('knob-l-r'), bgLR = document.getElementById('slider-h-bg'), fillH = document.getElementById('fill-h');
        const velocityDisplay = document.getElementById('velocity'), steeringDisplay = document.getElementById('steering');
        const wheelContainer = document.getElementById('wheel-container'), animatedWheel = document.getElementById('animated-wheel');

        let velocity = 0, steering = "", lastVelocity = 0, lastSteering = "";
        const maxVerticalRange = 120, maxHorizontalRange = 75;
        let touchIdFB = null, touchIdLR = null, updatePending = false;

        function updateUI() {
            velocityDisplay.innerText = Math.abs(velocity);
            if (velocity > 0) {
                velocityDisplay.className = "velocity-display val-positive"; wheelContainer.className = "wheel-container forward";
                animatedWheel.style.animation = `rotate-cw ${(105 - velocity) * 0.01}s linear infinite`;
            } else if (velocity < 0) {
                velocityDisplay.className = "velocity-display val-negative"; wheelContainer.className = "wheel-container backward";
                animatedWheel.style.animation = `rotate-ccw ${(105 - Math.abs(velocity)) * 0.01}s linear infinite`;
            } else {
                velocityDisplay.className = "velocity-display"; velocityDisplay.style.color = "#fff";
                wheelContainer.className = "wheel-container"; animatedWheel.style.animation = "none";
            }
            steeringDisplay.innerText = steering;
        }

        function queueSend() {
            if (!updatePending) {
                updatePending = true;
                requestAnimationFrame(() => {
                    if (velocity !== lastVelocity || steering !== lastSteering) {
                        fetch(`/drive?speed=${velocity}&steer=${steering}`).catch(()=>{});
                        lastVelocity = velocity; lastSteering = steering;
                    }
                    updatePending = false;
                });
            }
        }

        bgFB.addEventListener('touchstart', (e) => { e.preventDefault(); touchIdFB = e.changedTouches[0].identifier; handleFB(e.changedTouches[0].clientY); });
        window.addEventListener('touchmove', (e) => { if (touchIdFB === null) return; for (let t of e.touches) { if (t.identifier === touchIdFB) { handleFB(t.clientY); break; } } });
        window.addEventListener('touchend', (e) => {
            for (let t of e.changedTouches) { if (t.identifier === touchIdFB) { touchIdFB = null; knobFB.style.transform = "translateY(0px)"; fillV.style.height = "0%"; velocity = 0; updateUI(); queueSend(); break; } }
        });

        function handleFB(clientY) {
            const rect = bgFB.getBoundingClientRect(); let deltaY = clientY - (rect.top + rect.height / 2);
            deltaY = Math.max(-maxVerticalRange, Math.min(maxVerticalRange, deltaY));
            knobFB.style.transform = `translateY(${deltaY}px)`;
            if (deltaY < 0) { fillV.style.bottom = "50%"; fillV.style.height = `${(Math.abs(deltaY) / maxVerticalRange) * 50}%`; } 
            else { fillV.style.bottom = `${50 - (deltaY / maxVerticalRange) * 50}%`; fillV.style.height = `${(deltaY / maxVerticalRange) * 50}%`; }
            velocity = Math.round((-deltaY / maxVerticalRange) * 100); updateUI(); queueSend();
        }

        bgLR.addEventListener('touchstart', (e) => { e.preventDefault(); touchIdLR = e.changedTouches[0].identifier; handleLR(e.changedTouches[0].clientX); });
        window.addEventListener('touchmove', (e) => { if (touchIdLR === null) return; for (let t of e.touches) { if (t.identifier === touchIdLR) { handleLR(t.clientX); break; } } });
        window.addEventListener('touchend', (e) => {
            for (let t of e.changedTouches) { if (t.identifier === touchIdLR) { touchIdLR = null; knobLR.style.transform = "translateX(0px)"; fillH.style.width = "0%"; steering = ""; updateUI(); queueSend(); break; } }
        });

        function handleLR(clientX) {
            const rect = bgLR.getBoundingClientRect(); let deltaX = clientX - (rect.left + rect.width / 2);
            deltaX = Math.max(-maxHorizontalRange, Math.min(maxHorizontalRange, deltaX));
            knobLR.style.transform = `translateX(${deltaX}px)`;
            if (deltaX > 0) { fillH.style.left = "50%"; fillH.style.width = `${(deltaX / maxHorizontalRange) * 50}%`; } 
            else { fillH.style.left = `${50 - (Math.abs(deltaX) / maxHorizontalRange) * 50}%`; fillH.style.width = `${(Math.abs(deltaX) / maxHorizontalRange) * 50}%`; }
            steering = deltaX > 25 ? "R" : (deltaX < -25 ? "L" : ""); updateUI(); queueSend();
        }
    </script>
