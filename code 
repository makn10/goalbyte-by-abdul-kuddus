const int motorLeftDir1 = 13;  
const int motorLeftDir2 = 12;  

const int motorRightPWM = 25;  
const int motorRightDir1 = 14; 
const int motorRightDir2 = 27; 

int currentSpeed = 0;      
String currentSteering = ""; 

AsyncWebServer server(80);

